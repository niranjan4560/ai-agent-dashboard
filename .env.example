# .env.example
# Copy this file to .env and fill in your API keys

# Required for AI Agent chat
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for weather widget
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Required for news widget
NEWS_API_KEY=your_newsapi_org_key_here

# Required for GitHub activity widget
GITHUB_USERNAME=your_github_username_here
GITHUB_TOKEN=your_github_personal_access_token_here  # optional but increases rate limit

# Crypto widget uses CoinGecko — no API key needed!
